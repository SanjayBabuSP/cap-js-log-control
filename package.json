  "description": "CAP plugin for controlling CDS logger verbosity and OpenTelemetry DiagLogger noise — reduce log clutter, surface real errors",
  "main": "cds-plugin.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest --forceExit",
    "lint": "eslint src/**/*.ts",
