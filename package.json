  },
  "devDependencies": {
    "@sap/cds": "^8.0.0",
    "@opentelemetry/api": "^1.9.0",
    "typescript": "^5.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^22.0.0"
  },
  "files": [
    "cds-plugin.js",
    "dist/",
    "LICENSE",
    "README.md"
  ],
